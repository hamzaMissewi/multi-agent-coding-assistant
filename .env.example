# Multi-Agent Coding Assistant Environment Variables

# LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=qwen-3-70b-8192

# Application Settings
APP_HOST=localhost
APP_PORT=8501
DEBUG_MODE=false

# Project Generation
OUTPUT_DIRECTORY=./generated_projects
MAX_PROJECT_SIZE_MB=100

# Agent Settings
MAX_RETRIES=3
TEMPERATURE=0.1
MAX_TOKENS=4000
